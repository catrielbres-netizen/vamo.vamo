{
  "name": "functions",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest --testPathPattern=src/__tests__",
    "test:shared": "jest --testPathPattern=sharedHelpers"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^2.1.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.1",
    "geofire-common": "^6.0.0",
    "google-auth-library": "^10.6.2",
    "mercadopago": "^2.12.0",
    "nodemailer": "^8.0.5",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "firebase-functions-test": "^3.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "moduleNameMapper": {
      "^firebase-functions/v2/https$": "<rootDir>/src/__mocks__/firebase-functions-v2-https.ts",
      "^firebase-functions/logger$": "<rootDir>/src/__mocks__/firebase-functions-logger.ts",
      "^firebase-admin/firestore$": "<rootDir>/src/__mocks__/firebase-admin-firestore.ts"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  }
}
