rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helpers
    function signedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return signedIn() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. PUBLIC: Profile Photos (Avatars)
    // Matches path used in DriverProfilePage: profile_photos/{uid}/avatar.jpg
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == userId;
    }
    
    // Legacy/Alternative profile path
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == userId;
    }

    // 2. PUBLIC: Vehicle Photos
    // Matches path used in DriverRegisterClient: drivers/{uid}/{fileName}
    match /drivers/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == userId
                   && request.resource.contentType.matches('image/.*');
    }

    // 3. PRIVATE: Driver Sensitive Documents (Manual Review)
    // Matches path used in DriverProfilePage: driver_documents/{uid}/{docId}_{timestamp}.jpg
    match /driver_documents/{userId}/{allPaths=**} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if signedIn() && request.auth.uid == userId
                   && request.resource.contentType.matches('image/.*');
    }
    
    // 4. PRIVATE: Municipal Documents (Express Drivers)
    match /municipal_docs/{cityKey}/{userId}/{allPaths=**} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if signedIn() && request.auth.uid == userId;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
